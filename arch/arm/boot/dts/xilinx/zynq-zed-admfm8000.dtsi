#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/linux-event-codes.h>

/ {
	dds_clkin: clock-1ghz {
		#clock-cells = <0>;
		compatible = "fixed-clock";
		clock-frequency = <1000000000>; // 1GHz
	};

	dds_reg_3v3: dds-reg-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "dds-3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};

	dds_reg_1v8: dds-reg-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "dds-1v8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on;
	};

	pll_clkin: pll-clock {
		#clock-cells = <0>;
		compatible = "fixed-clock";
		clock-frequency = <50000000>; // 50MHz
	};

	pll_reg_3v3: pll-reg-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "pll-3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};

	att_reg_3v3: att-reg-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "att-3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};
};

&fpga_axi {
	/*
	tx_dma: dmac@7c480000 {
		compatible = "adi,axi-dmac-1.00.a";
		reg = <0x7c480000 0x1000>;
		#dma-cells = <1>;
		interrupt-parent = <&intc>;
		interrupts = <0 54 4>;
		clocks = <&clkc 16>; // fclk1

		adi,channels {
			#size-cells = <0>;
