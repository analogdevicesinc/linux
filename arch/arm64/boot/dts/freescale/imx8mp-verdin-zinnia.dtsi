		"",
		"",
		"",
		"",
		"",
		"";
};

&gpio4 {
	gpio-line-names =
		"", /* 0 */
		"DI3_EN", /* SODIMM 222 */
		"",
		"DO3_EN", /* SODIMM 220 */
		"",
		"",
		"",
		"",
		"",
		"",
		"", /* 10 */
		"",
		"",
		"",
		"",
		"",
