		"",
		"", /* 10 */
		"",
		"",
		"",
		"",
		"",
		"",
		"",
		"",
		"",
		""; /* 20 */
};

&gpio3 {
	gpio-line-names =
		"", /* 0 */
		"",
		"",
		"",
		"",
		"",
		"DI3_RB", /* SODIMM 56 */
		"",
		"",
		"",
		"", /* 10 */
		"",
		"",
		"",
		"",
		"",
		"",
