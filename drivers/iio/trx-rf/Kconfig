# RF Transceivers and Advanced Mixed Signal Frontends drivers
#
menu "RF Transceivers and Advanced Mixed Signal Frontends"

config AD9088
	tristate "Analog Devices AD9088 and similar Mixed Signal Front End (MxFE)"
	depends on SPI
	select CF_AXI_ADC
	select ADI_AXI_HSCI
	help
	  Say yes here to build support for Analog Devices:
	  AD9088, AD9084 mixed signal front end (MxFE).
	  Provides direct access via sysfs.

config ADRV903X
	tristate "Analog Devices ADRV903X/ADRV9030 RF Transceiver driver"
	depends on SPI
	select CF_AXI_ADC
	help
	  Say yes here to build support for Analog Devices:
	  ADRV903X/ADRV9030 RF Transceivers. Provides direct access
	  via sysfs.

	  To compile this driver as a module, choose M here: the module will be
	  called adrv903x_drv.

endmenu
